{
  "compilerOptions": {
    "baseUrl": "..",
    "paths": {
      "@/*": ["src/*"],
      "@tests/*": ["tests/*"]
    },
    "module": "commonjs",
    "target": "es6",
    "lib": ["es2023", "dom"],
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true
  },
  "include": [
    "./backend/**/*.ts",
    "./extension/**/*.ts",
    "./webview/**/*.ts",
    "../src/backend/**/*.ts",
    "../src/webview/**/*.ts"
  ]
}
